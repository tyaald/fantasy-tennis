# ⚠️ FOR TERMINAL/CLI DEPLOYS (Path B) ONLY.
# If you deploy from GitHub (Path A), do NOT add this file — its presence makes
# Cloudflare run the wrong (Workers) deploy command. To use the CLI path, rename
# this to "wrangler.toml" and fill in the KV id below.

# Cloudflare Pages config. The KV id below is a placeholder — fill it in after you
# create the namespace (see README), or bind it in the dashboard instead.
name = "tennis-pool"
pages_build_output_dir = "dist"
compatibility_date = "2024-09-23"

# Shared storage for the pool (picks, results, champions, settings).
[[kv_namespaces]]
binding = "POOL_KV"
id = "PUT_YOUR_KV_NAMESPACE_ID_HERE"
# preview_id = "PUT_A_PREVIEW_KV_ID_HERE"   # optional, for `wrangler pages dev`

# ANTHROPIC_API_KEY is a SECRET — do not put it here. Set it with:
#   npx wrangler pages secret put ANTHROPIC_API_KEY
# or in the dashboard (Settings -> Environment variables -> add as a secret).

# The "Join & Notify" tab (mailing list + draw-release email) needs three more
# SECRETS, same method as above:
#   npx wrangler pages secret put RESEND_API_KEY   # from resend.com
#   npx wrangler pages secret put FROM_EMAIL        # e.g. "Tennis Pool <pool@yourdomain.com>"
#   npx wrangler pages secret put SEND_PASSWORD     # any password you choose
#
# The automatic winners email (see README) needs one more:
#   npx wrangler pages secret put CRON_SECRET       # any random string, matches cron-worker's copy

